# Copy this file to backend/.env and fill in real values.
# backend/.env is gitignored — never commit real secrets.

PORT=5000

# --- Database ---
# Local (matches docker-compose.yml's postgres service):
DATABASE_URL=postgres://syncup:localdevpassword@localhost:5432/syncup
# Prod: your real Neon/RDS connection string (DB_connect.ts auto-enables
# SSL when the URL contains "neon.tech", so no change needed there).

# --- Redis ---
# Local (matches docker-compose.yml's redis service):
REDIS_URL=redis://localhost:6379

# --- Auth ---
JWT_SECRET=some-long-random-local-dev-secret

# --- CORS ---
# Must match the exact origin your frontend runs on.
FRONTEND_URL=http://localhost:3000

# --- AWS S3 (file uploads + Yjs document persistence) ---
# Optional for local dev: if you leave these blank, fileStorage.ts falls
# back to storing Yjs documents on local disk (backend/data/) instead of
# hitting S3. Only fill these in if you specifically want to test the real
# upload path against your actual bucket.
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_REGION=
S3_BUCKET=